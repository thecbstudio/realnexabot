# Admin panel şifresi (ilk başlatmada otomatik hash'lenir)
ADMIN_PASSWORD=changeme123

# JWT imzalama secret'i (uzun, rastgele bir string gir)
ADMIN_TOKEN=your-super-secret-jwt-key-change-this

# Anthropic / Claude API anahtarı
ANTHROPIC_API_KEY=sk-ant-...

# Dakikada max chat isteği (default: 20)
CHAT_RATE_LIMIT=20

# CORS: virgülle ayrılmış izinli originler. Boş bırakırsan herkese açık.
# Örn: https://siteniz.com,https://www.siteniz.com
ALLOWED_ORIGINS=

# Embed script için base URL (boş bırakırsan request header'larından otomatik üretilir)
# Örn: https://nexabot.example.com
BASE_URL=

# Sunucu portu (default: 3000)
PORT=3000
